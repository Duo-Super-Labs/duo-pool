{
  "name": "duopool",
  "private": true,
  "version": "0.0.0",
  "description": "Live polls demo for AI Amplifica talk @ Univali",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "bun --filter @duopool/database db:migrate",
    "db:seed": "bun --filter @duopool/database db:seed",
    "db:studio": "bun --filter @duopool/database db:studio"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.5.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  }
}
