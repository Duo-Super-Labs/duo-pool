{
  "name": "@duopool/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/zod": "./src/schema/zod.ts",
    "./query/polls": "./src/query/polls.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "bun --env-file=../../.env.test bun:test",
    "bun:test": "bun test",
    "db:generate": "bun --env-file=../../.env.local --bun drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env.local src/migrate.ts",
    "db:migrate:test": "bun --env-file=../../.env.test src/migrate.ts",
    "db:seed": "bun --env-file=../../.env.local src/seed.ts",
    "db:studio": "bun --env-file=../../.env.local --bun drizzle-kit studio",
    "db:push": "bun --env-file=../../.env.local --bun drizzle-kit push"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.6.3"
  }
}
